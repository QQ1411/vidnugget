# Copy this to .env and fill in your values
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: OpenAI Whisper model size (tiny, base, small, medium, large)
# Larger = more accurate but slower. 'base' is a good default.
WHISPER_MODEL=base

# Port to run the server on
PORT=8000

# Host (use 0.0.0.0 to allow access from other devices on your network, e.g. your phone)
HOST=0.0.0.0
